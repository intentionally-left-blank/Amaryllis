{
  "contract": "news_mission_v1",
  "version": "0.1.0-draft",
  "description": "Contract for autonomous news missions (plan/create/run/digest) with grounded citations.",
  "entities": {
    "source_item": {
      "required": [
        "source",
        "canonical_id",
        "url",
        "title",
        "published_at"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "reddit",
            "x",
            "web"
          ]
        },
        "canonical_id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "excerpt": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "ingested_at": {
          "type": "string",
          "format": "date-time"
        },
        "raw_score": {
          "type": "number"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "digest_entry": {
      "required": [
        "section",
        "summary",
        "citations"
      ],
      "properties": {
        "section": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source",
              "url",
              "title"
            ],
            "properties": {
              "source": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/news/missions/plan",
      "request": {
        "required": [
          "agent_id",
          "user_id",
          "topic"
        ],
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "topic": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "reddit",
                "x",
                "web"
              ]
            }
          },
          "window_hours": {
            "type": "integer",
            "minimum": 1,
            "maximum": 168
          },
          "timezone": {
            "type": "string"
          },
          "schedule_type": {
            "type": "string"
          },
          "schedule": {
            "type": "object",
            "additionalProperties": true
          },
          "start_immediately": {
            "type": "boolean"
          }
        }
      },
      "response": {
        "required": [
          "mission_plan",
          "apply_hint",
          "request_id"
        ],
        "properties": {
          "mission_plan": {
            "type": "object",
            "additionalProperties": true
          },
          "apply_hint": {
            "type": "object",
            "properties": {
              "endpoint": {
                "type": "string"
              },
              "payload": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/missions/create",
      "request": {
        "required": [
          "agent_id",
          "user_id",
          "topic",
          "schedule_type",
          "schedule"
        ],
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "topic": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "window_hours": {
            "type": "integer"
          },
          "timezone": {
            "type": "string"
          },
          "schedule_type": {
            "type": "string"
          },
          "schedule": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "response": {
        "required": [
          "automation",
          "request_id"
        ],
        "properties": {
          "automation": {
            "type": "object",
            "additionalProperties": true
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/news/digests",
      "request": {
        "properties": {
          "user_id": {
            "type": "string"
          },
          "topic": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        }
      },
      "response": {
        "required": [
          "items",
          "count",
          "request_id"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "digest_id",
                "topic",
                "generated_at",
                "entries"
              ],
              "properties": {
                "digest_id": {
                  "type": "string"
                },
                "topic": {
                  "type": "string"
                },
                "generated_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "entries": {
                  "type": "array",
                  "items": {
                    "$ref": "#/entities/digest_entry"
                  }
                }
              }
            }
          },
          "count": {
            "type": "integer"
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    }
  ]
}
