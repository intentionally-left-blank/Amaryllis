{
  "contract": "news_mission_v1",
  "version": "0.5.0-draft",
  "description": "Contract for first-class news agents (create/list), autonomous news missions (plan/create/ingest/list), and outbound digest delivery policy controls.",
  "entities": {
    "source_item": {
      "required": [
        "source",
        "canonical_id",
        "canonical_story_key",
        "url",
        "title",
        "published_at"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["reddit", "x", "web"]
        },
        "canonical_id": {"type": "string"},
        "canonical_story_key": {"type": "string"},
        "url": {"type": "string"},
        "title": {"type": "string"},
        "excerpt": {"type": "string"},
        "author": {"type": "string"},
        "published_at": {"type": "string", "format": "date-time"},
        "ingested_at": {"type": "string", "format": "date-time"},
        "raw_score": {"type": "number"},
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "canonical_story_key": {"type": "string"},
            "merged_sources": {"type": "array", "items": {"type": "string"}},
            "merged_count": {"type": "integer"},
            "provenance": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
            "dedup_policy": {"type": "object", "additionalProperties": true}
          }
        }
      }
    },
    "news_agent": {
      "required": ["news_agent_id", "name", "managed"],
      "properties": {
        "news_agent_id": {"type": "string"},
        "name": {"type": "string"},
        "user_id": {"type": "string"},
        "created_at": {"type": "string", "format": "date-time"},
        "managed": {"type": "boolean"},
        "is_default": {"type": "boolean"}
      }
    },
    "internet_scope": {
      "properties": {
        "queries": {"type": "array", "items": {"type": "string"}},
        "include_domains": {"type": "array", "items": {"type": "string"}},
        "exclude_domains": {"type": "array", "items": {"type": "string"}},
        "seed_urls": {"type": "array", "items": {"type": "string"}},
        "languages": {"type": "array", "items": {"type": "string"}},
        "regions": {"type": "array", "items": {"type": "string"}},
        "max_depth": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    },
    "outbound_channel_policy": {
      "required": ["channel"],
      "properties": {
        "channel": {"type": "string", "enum": ["webhook", "email", "telegram"]},
        "enabled": {"type": "boolean"},
        "max_targets": {"type": "integer", "minimum": 1, "maximum": 20},
        "targets": {"type": "array", "items": {"type": "string"}},
        "options": {"type": "object", "additionalProperties": true}
      }
    }
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/news/agents/create",
      "request": {
        "properties": {
          "user_id": {"type": "string"},
          "name": {"type": "string"},
          "focus": {"type": "string"},
          "model": {"type": "string"},
          "tools": {"type": "array", "items": {"type": "string"}},
          "set_default": {"type": "boolean"}
        }
      },
      "response": {
        "required": ["news_agent", "request_id"],
        "properties": {
          "news_agent": {"$ref": "#/entities/news_agent"},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "GET",
      "path": "/news/agents",
      "request": {
        "properties": {
          "user_id": {"type": "string"}
        }
      },
      "response": {
        "required": ["items", "count", "request_id"],
        "properties": {
          "items": {"type": "array", "items": {"$ref": "#/entities/news_agent"}},
          "count": {"type": "integer"},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/agents/quickstart",
      "request": {
        "properties": {
          "user_id": {"type": "string"},
          "request": {"type": "string"},
          "topic": {"type": "string"},
          "focus": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string", "enum": ["reddit", "x", "web"]}},
          "window_hours": {"type": "integer", "minimum": 1, "maximum": 168},
          "max_items_per_source": {"type": "integer", "minimum": 1, "maximum": 100},
          "timezone": {"type": "string"},
          "schedule_type": {"type": "string"},
          "schedule": {"type": "object", "additionalProperties": true},
          "interval_sec": {"type": "integer", "minimum": 10, "maximum": 86400},
          "start_immediately": {"type": "boolean"},
          "internet_scope": {"$ref": "#/entities/internet_scope"},
          "source_overrides": {"type": "object", "additionalProperties": true},
          "session_id": {"type": "string"}
        }
      },
      "response": {
        "required": ["news_agent", "resolved_topic", "mission_plan", "automation", "request_id"],
        "properties": {
          "news_agent": {"$ref": "#/entities/news_agent"},
          "resolved_topic": {"type": "string"},
          "mission_plan": {"type": "object", "additionalProperties": true},
          "automation": {"type": "object", "additionalProperties": true},
          "assistant_reply": {"type": "string"},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/missions/plan",
      "request": {
        "required": ["topic"],
        "properties": {
          "news_agent_id": {"type": "string"},
          "agent_id": {"type": "string"},
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string", "enum": ["reddit", "x", "web"]}},
          "window_hours": {"type": "integer", "minimum": 1, "maximum": 168},
          "max_items_per_source": {"type": "integer", "minimum": 1, "maximum": 100},
          "timezone": {"type": "string"},
          "schedule_type": {"type": "string"},
          "schedule": {"type": "object", "additionalProperties": true},
          "interval_sec": {"type": "integer", "minimum": 10, "maximum": 86400},
          "start_immediately": {"type": "boolean"},
          "internet_scope": {"$ref": "#/entities/internet_scope"},
          "source_overrides": {"type": "object", "additionalProperties": true}
        }
      },
      "response": {
        "required": ["news_agent", "mission_plan", "apply_hint", "automation_apply_hint", "request_id"],
        "properties": {
          "news_agent": {"$ref": "#/entities/news_agent"},
          "mission_plan": {"type": "object", "additionalProperties": true},
          "apply_hint": {"type": "object", "additionalProperties": true},
          "automation_apply_hint": {"type": "object", "additionalProperties": true},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/missions/create",
      "request": {
        "required": ["topic"],
        "properties": {
          "news_agent_id": {"type": "string"},
          "agent_id": {"type": "string"},
          "user_id": {"type": "string"},
          "session_id": {"type": "string"},
          "topic": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string"}},
          "window_hours": {"type": "integer", "minimum": 1, "maximum": 168},
          "max_items_per_source": {"type": "integer", "minimum": 1, "maximum": 100},
          "timezone": {"type": "string"},
          "schedule_type": {"type": "string"},
          "schedule": {"type": "object", "additionalProperties": true},
          "interval_sec": {"type": "integer", "minimum": 10, "maximum": 86400},
          "start_immediately": {"type": "boolean"},
          "internet_scope": {"$ref": "#/entities/internet_scope"},
          "source_overrides": {"type": "object", "additionalProperties": true}
        }
      },
      "response": {
        "required": ["news_agent", "mission_plan", "automation", "request_id"],
        "properties": {
          "news_agent": {"$ref": "#/entities/news_agent"},
          "mission_plan": {"type": "object", "additionalProperties": true},
          "automation": {"type": "object", "additionalProperties": true},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/ingest/preview",
      "request": {
        "required": ["topic"],
        "properties": {
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string"}},
          "window_hours": {"type": "integer", "minimum": 1, "maximum": 168},
          "max_items_per_source": {"type": "integer", "minimum": 1, "maximum": 100},
          "internet_scope": {"$ref": "#/entities/internet_scope"},
          "persist": {"type": "boolean"}
        }
      },
      "response": {
        "required": ["report", "request_id"],
        "properties": {
          "report": {"type": "object", "additionalProperties": true},
          "persisted_count": {"type": "integer"},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/delivery/policies/upsert",
      "request": {
        "properties": {
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "channels": {"type": "array", "items": {"$ref": "#/entities/outbound_channel_policy"}}
        }
      },
      "response": {
        "required": ["topic_scope", "items", "count", "request_id"],
        "properties": {
          "topic_scope": {"type": "string"},
          "persisted_count": {"type": "integer"},
          "items": {"type": "array", "items": {"$ref": "#/entities/outbound_channel_policy"}},
          "count": {"type": "integer"},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "GET",
      "path": "/news/delivery/policies",
      "request": {
        "properties": {
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "include_global": {"type": "boolean"}
        }
      },
      "response": {
        "required": ["items", "count", "request_id"],
        "properties": {
          "items": {"type": "array", "items": {"$ref": "#/entities/outbound_channel_policy"}},
          "count": {"type": "integer"},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "GET",
      "path": "/news/delivery/events",
      "request": {
        "properties": {
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "channel": {"type": "string", "enum": ["webhook", "email", "telegram"]},
          "limit": {"type": "integer", "minimum": 1, "maximum": 1000}
        }
      },
      "response": {
        "required": ["items", "count", "request_id"],
        "properties": {
          "items": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
          "count": {"type": "integer"},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "POST",
      "path": "/news/digest/compose",
      "request": {
        "required": ["topic"],
        "properties": {
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "source": {"type": "string", "enum": ["reddit", "x", "web"]},
          "limit": {"type": "integer", "minimum": 1, "maximum": 1000},
          "deliver_to_inbox": {"type": "boolean"},
          "inbox_title": {"type": "string"},
          "deliver_to_outbound": {"type": "boolean"},
          "outbound_channels": {"type": "array", "items": {"type": "string", "enum": ["webhook", "email", "telegram"]}},
          "outbound_dry_run": {"type": "boolean"}
        }
      },
      "response": {
        "required": ["digest", "item_count", "request_id"],
        "properties": {
          "digest": {"type": "object", "additionalProperties": true},
          "item_count": {"type": "integer"},
          "inbox_item": {"type": "object", "additionalProperties": true},
          "outbound_delivery": {"type": "object", "additionalProperties": true},
          "outbound_event_count": {"type": "integer"},
          "action_receipt": {"type": "object", "additionalProperties": true},
          "request_id": {"type": "string"}
        }
      }
    },
    {
      "method": "GET",
      "path": "/news/items",
      "request": {
        "properties": {
          "user_id": {"type": "string"},
          "topic": {"type": "string"},
          "source": {"type": "string", "enum": ["reddit", "x", "web"]},
          "limit": {"type": "integer", "minimum": 1, "maximum": 1000}
        }
      },
      "response": {
        "required": ["items", "count", "request_id"],
        "properties": {
          "items": {"type": "array", "items": {"$ref": "#/entities/source_item"}},
          "count": {"type": "integer"},
          "request_id": {"type": "string"}
        }
      }
    }
  ]
}
