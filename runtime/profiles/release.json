{
  "schema_version": 1,
  "profile": "release",
  "description": "Release profile for production shipping gates with strict controls and release SLO budgets.",
  "slo_profile": "release",
  "required_env": [
    "AMARYLLIS_AUTH_TOKENS"
  ],
  "env_defaults": {
    "AMARYLLIS_SECURITY_PROFILE": "production",
    "AMARYLLIS_RELEASE_CHANNEL": "stable",
    "AMARYLLIS_TOOL_APPROVAL_ENFORCEMENT": "strict",
    "AMARYLLIS_TOOL_SANDBOX_ENABLED": true,
    "AMARYLLIS_QOS_MODE": "balanced",
    "AMARYLLIS_QOS_AUTO_ENABLED": true,
    "AMARYLLIS_QOS_THERMAL_STATE": "unknown",
    "AMARYLLIS_PLUGIN_SIGNING_MODE": "strict",
    "AMARYLLIS_PLUGIN_RUNTIME_MODE": "sandboxed"
  }
}
