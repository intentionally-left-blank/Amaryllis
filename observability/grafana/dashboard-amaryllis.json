{
  "title": "Amaryllis Runtime SRE",
  "schemaVersion": 39,
  "version": 3,
  "panels": [
    {
      "type": "stat",
      "title": "Request Availability",
      "targets": [
        {
          "expr": "amaryllis_request_availability_ratio"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Request Latency p95 (ms)",
      "targets": [
        {
          "expr": "amaryllis_request_latency_p95_ms"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Run Success Ratio",
      "targets": [
        {
          "expr": "amaryllis_run_success_ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Budget Burn Rate",
      "targets": [
        {
          "expr": "amaryllis_error_budget_burn_rate{scope=\"requests\"}",
          "legendFormat": "requests"
        },
        {
          "expr": "amaryllis_error_budget_burn_rate{scope=\"runs\"}",
          "legendFormat": "runs"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Open Incidents",
      "targets": [
        {
          "expr": "amaryllis_open_incidents_total"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Release Snapshot Loaded",
      "targets": [
        {
          "expr": "amaryllis_release_quality_snapshot_loaded"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Release Quality Score (%)",
      "targets": [
        {
          "expr": "amaryllis_release_quality_score_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Release Quality Status",
      "targets": [
        {
          "expr": "amaryllis_release_quality_status"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Desktop Staging Status",
      "targets": [
        {
          "expr": "amaryllis_release_desktop_staging_status"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Desktop Staging Error Rate (%)",
      "targets": [
        {
          "expr": "amaryllis_release_desktop_staging_error_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Release QoS Gate Status",
      "targets": [
        {
          "expr": "amaryllis_release_qos_status"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Release QoS Gate Checks Failed",
      "targets": [
        {
          "expr": "amaryllis_release_qos_checks_failed"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Install Success (%)",
      "targets": [
        {
          "expr": "amaryllis_release_adoption_install_success_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Retention Proxy (%)",
      "targets": [
        {
          "expr": "amaryllis_release_adoption_retention_proxy_success_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Feature Rate (%)",
      "targets": [
        {
          "expr": "amaryllis_release_adoption_feature_adoption_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Channel Coverage (%)",
      "targets": [
        {
          "expr": "amaryllis_release_adoption_channel_manifest_coverage_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "API Quickstart Pass (%)",
      "targets": [
        {
          "expr": "amaryllis_release_adoption_api_quickstart_pass_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Snapshot Loaded",
      "targets": [
        {
          "expr": "amaryllis_adoption_snapshot_loaded"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Status",
      "targets": [
        {
          "expr": "amaryllis_adoption_status"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Activation Success (%)",
      "targets": [
        {
          "expr": "amaryllis_adoption_activation_success_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Adoption Activation Blocked (%)",
      "targets": [
        {
          "expr": "amaryllis_adoption_activation_blocked_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nightly Snapshot Loaded",
      "targets": [
        {
          "expr": "amaryllis_nightly_mission_snapshot_loaded"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nightly Mission Status",
      "targets": [
        {
          "expr": "amaryllis_nightly_mission_status"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nightly Success Rate (%)",
      "targets": [
        {
          "expr": "amaryllis_nightly_success_rate_pct"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nightly Burn-Rate Gate",
      "targets": [
        {
          "expr": "amaryllis_nightly_burn_rate_gate_passed"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nightly Adoption Trend Gate",
      "targets": [
        {
          "expr": "amaryllis_nightly_adoption_trend_gate_passed"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Nightly Adoption Regressed",
      "targets": [
        {
          "expr": "amaryllis_nightly_adoption_trend_regressed_metrics"
        }
      ]
    }
  ]
}
